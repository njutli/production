diff --git a/config.sh b/config.sh
index c2537de..cf7025a 100755
--- a/config.sh
+++ b/config.sh
@@ -3,11 +3,22 @@
 # Production Deployment Configuration (4 Machines)
 #   1 × TiKV  (single node, single replica)
 #   3 × Ceph   (MON+MGR+OSD+RGW, EC 4+2)
+#   3 × MinIO  (alternative lightweight object storage)
 #   Client: shared on TiKV or Ceph machines (see README)
 #
+# Storage backend: set STORAGE_BACKEND to "ceph" or "minio".
+# All S3 connection variables (endpoint, keys, bucket URL) are
+# computed below based on this choice — scripts should use them
+# instead of backend-specific names.
+#
 # Edit this file with your actual server IPs before running.
 # ============================================================
 
+# --- Storage Backend Selection ---
+# "ceph"  — Ceph RGW (RADOS Gateway) S3 API
+# "minio" — MinIO distributed object storage S3 API
+STORAGE_BACKEND="${STORAGE_BACKEND:-ceph}"
+
 # --- TiKV: Single Node (PD + TiKV co-located) ---
 # This machine serves JuiceFS metadata.
 # Running single-replica mode (no Raft group).
@@ -35,7 +46,7 @@ CEPH_SERVERS=(
 # per server).  Each disk will be split into 2 equal partitions by
 # deploy-ceph.sh → 3 servers × 2 partitions = 6 OSDs for EC 4+2.
 # Index matches CEPH_SERVERS.
-#   ceph-node1: sdb=953G (reinstalled 2026-06; system now on sda, sdb freed)
+#   ceph-node1: sdb=953G
 #   ceph-node2: sdb=953G
 #   ceph-node3: sdb=953G
 # Capacity: all OSD disks ~953G → EC 4+2 usable ~1.9T (efficiency ~67%)
@@ -49,12 +60,36 @@ CEPH_EC_K=4
 CEPH_EC_M=2
 CEPH_FAILURE_DOMAIN="osd"
 
+# --- MinIO Cluster (3 servers, distributed mode) ---
+# Lightweight alternative to Ceph.  Each node runs a MinIO server
+# that uses the same data disk (sdb).  MinIO handles its own EC
+# internally; no LVM/OSD/RGW complexity.
+# 3 nodes × 2 directories-per-node = 6 "drives" → EC 4+2.
+MINIO_SERVERS=(
+  "192.168.11.11"   # minio-node1
+  "192.168.11.13"   # minio-node2
+  "192.168.11.14"   # minio-node3
+)
+
+MINIO_DATA_DEVICE="/dev/sdb"
+MINIO_MOUNT="/data/minio"
+MINIO_PORT=9000
+MINIO_CONSOLE_PORT=9001
+MINIO_ACCESS_KEY="juicefs"
+MINIO_SECRET_KEY="juicefs123"
+
+# MinIO EC parity configuration
+# k=4 data shards + m=2 parity shards = 6 total
+# Must match the total drive count.  Usable = k/(k+m) ≈ 67%.
+MINIO_EC_K=4
+MINIO_EC_M=2
+
 # --- JuiceFS Client ---
 # Which machine runs JuiceFS mount (FUSE process).
 # Per our strategy:
 #   Data-heavy tests  → ${TIKV_SERVER}
 #   Metadata-heavy tests → one of CEPH_SERVERS
-# Set this before each test run; scripts use PD_ENDPOINTS + RGW_ENDPOINT.
+# Set this before each test run; scripts use PD_ENDPOINTS + S3_ENDPOINT.
 JUICEFS_CLIENT="${TIKV_SERVER}"
 
 JUICEFS_FS_NAME="juicefs-prod"
@@ -75,33 +110,55 @@ SSH_OPTS="-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLeve
 PD_ENDPOINTS="${TIKV_SERVER}:2379"
 
 # --- Ceph RGW endpoint (for JuiceFS S3 access) ---
-# With a single RGW, point JuiceFS directly at it (e.g. CEPH_SERVERS[0]:8000).
-# With multiple RGWs, deploy an LB (deploy-lb.sh) and set RGW_ENDPOINT to
-# the LB address so traffic is spread across all RGW backends — otherwise
-# JuiceFS only ever talks to one RGW.
-# NOTE: defined after the LB block below so ${LB_HOST}/${LB_PORT} are set.
+# With multiple RGWs + LB, point JuiceFS at the LB address.
+# With a single RGW, point directly at it (e.g. CEPH_SERVERS[0]:8000).
+# NOTE: defined after LB_HOST/LB_PORT below so those variables are set.
 
 # --- RGW load balancer (HAProxy) ---
 # Only meaningful when there is more than one RGW.  deploy-lb.sh installs
 # HAProxy on LB_HOST and balances LB_PORT across RGW_BACKENDS (round-robin
-# with health checks).  After running it, set RGW_ENDPOINT above to
-# "http://${LB_HOST}:${LB_PORT}".
+# with health checks).
 #
 # LB_HOST: where HAProxy runs.  Default = TiKV node (gigabit, not an RGW
 # host, so the LB itself isn't competing with an RGW for the same NIC).
 LB_HOST="${TIKV_SERVER}"
 LB_PORT="8080"
 # RGW backends the LB fans out to (ip:port).  Must match the RGW placement
-# in deploy-ceph.sh (currently ceph-node1 + ceph-node3, both :8000).
+# in deploy-ceph.sh (currently ceph-node1 + ceph-node2 + ceph-node3, all :8000).
 RGW_BACKENDS=(
   "${CEPH_SERVERS[0]}:8000"   # ceph-node1
   "${CEPH_SERVERS[1]}:8000"   # ceph-node2
   "${CEPH_SERVERS[2]}:8000"   # ceph-node3
 )
 
-# JuiceFS S3 endpoint: point at the LB so both RGWs get traffic.
-# (For single-RGW setups, set this to "http://${CEPH_SERVERS[0]}:8000".)
 RGW_ENDPOINT="http://${LB_HOST}:${LB_PORT}"
 
+# --- MinIO load balancer (HAProxy) ---
+# Same pattern as RGW LB: HAProxy on tikv-node balances across all MinIO
+# nodes.  Deployed by deploy-minio.sh when STORAGE_BACKEND=minio.
+MINIO_LB_PORT="8081"
+MINIO_BACKENDS=(
+  "${MINIO_SERVERS[0]}:${MINIO_PORT}"   # minio-node1
+  "${MINIO_SERVERS[1]}:${MINIO_PORT}"   # minio-node2
+  "${MINIO_SERVERS[2]}:${MINIO_PORT}"   # minio-node3
+)
+
+# --- Computed S3 connection variables ---
+# Scripts should use these instead of backend-specific names.
+case "${STORAGE_BACKEND}" in
+    ceph)
+        S3_ENDPOINT="${RGW_ENDPOINT}"
+        ;;
+    minio)
+        S3_ENDPOINT="http://${LB_HOST}:${MINIO_LB_PORT}"
+        ;;
+    *)
+        echo "ERROR: unknown STORAGE_BACKEND='${STORAGE_BACKEND}' (use 'ceph' or 'minio')"
+        exit 1
+        ;;
+esac
+
+BUCKET_URL="${S3_ENDPOINT}/${JUICEFS_FS_NAME}"
+
 # --- Binary download mirror ---
 TIKV_MIRROR="https://tiup-mirrors.pingcap.com"
